# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/bootnode

# JWT
JWT_SECRET=replace-with-a-strong-jwt-secret
JWT_EXPIRE=30d
REFRESH_TOKEN_SECRET=replace-with-a-strong-refresh-secret
REFRESH_TOKEN_EXPIRE=90d

# Rate limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
